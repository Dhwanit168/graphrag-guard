# Copy this file to .env and fill in your real keys.
# .env is loaded automatically by app.py via python-dotenv.
# Never commit the real .env file — add it to .gitignore.

GEMINI_API_KEY=
COGNEE_URL=https://your-instance.cognee.ai

# Only needed if your Cognee instance enforces authentication
# (REQUIRE_AUTHENTICATION=true). Leave blank otherwise.
COGNEE_API_KEY=
